{
  "$schema": "./node_modules/knip/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "project": ["*.{ts,js}"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    },
    "packages/mcp": {
      "project": ["src/**/*.ts"]
    },
    "packages/plugin": {
      "project": ["src/**/*.ts", "ui/**/*.{ts,vue}"],
      "ignoreDependencies": ["tailwindcss"]
    }
  }
}
