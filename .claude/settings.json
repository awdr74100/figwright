{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/scripts/format-on-edit.mjs\"",
            "statusMessage": "oxfmt + oxlint on edited file"
          }
        ]
      }
    ]
  }
}
