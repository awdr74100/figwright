{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.tsbuildinfo",
    "pnpm-lock.yaml",
    ".claude/skills/**"
  ],
  "arrowParens": "avoid",
  "singleQuote": true,
  "printWidth": 100,
  "sortImports": {},
  "sortPackageJson": {
    "sortScripts": true
  },
  "jsdoc": {}
}
