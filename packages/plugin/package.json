{
  "name": "@figma-mcp-relay/plugin",
  "version": "0.0.0",
  "private": true,
  "description": "Figma plugin for figma-mcp-relay — UI + sandbox code.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:main && pnpm run build:ui",
    "build:main": "vite build --config vite.config.main.ts",
    "build:ui": "vite build --config vite.config.ts",
    "dev": "vite build --config vite.config.ts --watch",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@figma-mcp-relay/shared": "workspace:*",
    "@figma/plugin-typings": "^1.128.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vue-tsc": "^3.3.3"
  }
}
