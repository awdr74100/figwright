{
  "name": "@figwright/mcp",
  "version": "0.0.0",
  "description": "MCP server for Figwright — bridges MCP clients to a Figma plugin over local WebSocket.",
  "license": "MIT",
  "bin": {
    "figwright-mcp": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@figwright/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@msgpack/msgpack": "^3.1.3",
    "ignore": "^7.0.5",
    "oxc-parser": "^0.134.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsdown": "^0.22.2"
  }
}
