{
  "name": "@figma-mcp-relay/server",
  "version": "0.0.0",
  "description": "MCP server for figma-mcp-relay — bridges MCP clients to a Figma plugin over local WebSocket.",
  "license": "MIT",
  "bin": {
    "figma-mcp-relay": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@figma-mcp-relay/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@msgpack/msgpack": "^3.1.3",
    "oxc-parser": "^0.133.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsdown": "^0.22.0"
  }
}
